rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { 
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider in ['google.com', 'password']
      );
    }
    
    // Auth tokens NEVER contain custom claims. We trust email for dev and DB for roles.
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'ashishnehra450@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'phone', 'age', 'balance', 'role', 'referralCode'])
        && data.uid == request.auth.uid
        && data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 20
        && data.age is number && data.age >= 0 && data.age <= 150
        && data.balance is number && data.balance >= 0
        && data.role in ['user', 'admin']
        && data.referralCode is string && data.referralCode.size() <= 32
        && (data.get('name', '') is string && data.get('name', '').size() <= 128)
        && (data.get('kyc_url', '') is string && data.get('kyc_url', '').size() <= 1024)
        && (data.get('bank_details', '') is string && data.get('bank_details', '').size() <= 2048);
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['uid', 'userName', 'amount', 'status', 'timestamp'])
        && data.uid == request.auth.uid
        && data.amount is number && data.amount > 0
        && data.status == 'pending'
        && data.timestamp is string && data.timestamp.size() <= 128;
    }

    // --- Collections ---

    match /users/{userId} {
      // Basic read permissions
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isSignedIn() && (
        request.auth.token.email == 'ashishnehra450@gmail.com'
        || isAdmin() 
        || resource.data.referredBy == request.auth.uid
      );
      
      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().role == 'user'
        && incoming().balance == 0
        && incoming().createdAt == request.time;

      allow update: if (isAdmin() || isOwner(userId)) && (
        // Admin Escape Hatch
        isAdmin() || (
          isValidUser(incoming()) && 
          incoming().uid == existing().uid &&
          incoming().role == existing().role &&
          incoming().balance == existing().balance &&
          incoming().referralCode == existing().referralCode &&
          (
            // Action: Update Profile
            incoming().diff(existing()).affectedKeys().hasOnly(['name', 'kyc_url', 'bank_details', 'updatedAt']) ||
            // Action: Dev Self-Admin (Only for the verified dev email)
            (request.auth.token.email == 'ashishnehra450@gmail.com' && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'updatedAt']))
          )
          && incoming().updatedAt == request.time
        )
      );
    }

    match /withdrawals/{withdrawalId} {
      allow get: if isSignedIn() && (isOwner(resource.data.uid) || isAdmin());
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() 
        && isValidId(withdrawalId)
        && isValidWithdrawal(incoming());

      allow update: if isAdmin() 
        && existing().status == 'pending'
        && incoming().diff(existing()).affectedKeys().hasAny(['status', 'reason', 'net_payout'])
        && incoming().uid == existing().uid
        && incoming().amount == existing().amount;
      
      allow delete: if isAdmin();
    }

    match /vip_requests/{requestId} {
      allow get: if isSignedIn() && (isOwner(resource.data.uid) || isAdmin());
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() 
        && isValidId(requestId) 
        && incoming().uid == request.auth.uid
        && incoming().status == 'pending'
        && incoming().transactionId is string && incoming().transactionId.size() <= 128;

      allow update: if isAdmin() && existing().status == 'pending';
    }

    match /ad_rewards/{id} {
      allow get: if isSignedIn() && (isOwner(resource.data.uid) || isAdmin());
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().uid == request.auth.uid; 
    }

    match /referral_earnings/{id} {
      allow get: if isSignedIn() && (isOwner(resource.data.uid) || isAdmin());
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAdmin();
    }

    match /enquiries/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
